# Supabase (optional — app works with localStorage without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI features (optional — the app works fully with AI off).
# These are SERVER-ONLY (no NEXT_PUBLIC_ prefix): the key never reaches the browser.
# Pick ONE provider via AI_PROVIDER (openai | anthropic | gemini).

# OpenAI (default)
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# To use Anthropic Claude instead, set AI_PROVIDER=anthropic and provide:
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# To use Google Gemini instead, set AI_PROVIDER=gemini and provide:
# GEMINI_API_KEY=your-gemini-key   (free key at https://aistudio.google.com/apikey)
# GEMINI_MODEL=gemini-2.5-flash
