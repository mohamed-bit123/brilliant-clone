# Supabase (optional — app works with localStorage without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI features (optional — the app works fully with AI off).
# Get a free Gemini key at https://aistudio.google.com/apikey
# These are SERVER-ONLY (no NEXT_PUBLIC_ prefix): the key never reaches the browser.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# To use Anthropic Claude instead, set AI_PROVIDER=anthropic and provide:
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
